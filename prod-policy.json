{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "ec2:*",
        "s3:*",
        "lambda:*",
        "logs:*",
        "guardduty:*",
        "securityhub:*",
        "events:*",
        "kms:*",
        "dynamodb:*",
        "apigateway:*",
        "ssm:*",
        "bedrock:*",
        "cloudtrail:*",
        "config:*",
        "sns:*",
        "cloudwatch:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "ap-south-1"
        }
      }
    },
    {
      "Effect": "Allow",
      "Action": "iam:*",
      "Resource": "*"
    }
  ]
}